{
  "name": "x402-registry",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "x402 Universal Service Registry — npm for autonomous agent APIs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "compile": "npx hardhat compile",
    "deploy:sepolia": "npx hardhat run contracts/deploy.js --network base-sepolia"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "lucide-react": "^0.383.0",
    "recharts": "^2.12.0",
    "express": "^4.18.2",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "ethers": "^6.11.0",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
